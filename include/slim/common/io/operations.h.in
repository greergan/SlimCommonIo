#pragma once
#include <sys/socket.h>
#include <sys/stat.h>
#include <fcntl.h>
#include <cstdint>
#include <span>
#include <linux/io_uring.h>
#include <slim/common/io/awaitable.h>

#define SLIMCOMMONIO_VERSION  "@SLIMCOMMONIO_VERSION@"
#define SLIMCOMMONIO_GIT_HASH "@SLIMCOMMONIO_GIT_HASH@"

namespace slim::common::io {

class Scheduler;

struct Accept : Awaitable {
    int              server_fd;
    sockaddr_storage addr{};
    socklen_t        addr_len{sizeof(addr)};

    Accept(Scheduler& scheduler, int server_fd);

protected:
    void prepare(io_uring_sqe* sqe) noexcept override;
};

struct Close : Awaitable {
    int fd;

    Close(Scheduler& scheduler, int fd);

protected:
    void prepare(io_uring_sqe* sqe) noexcept override;
};

struct Connect : Awaitable {
    int              fd;
    sockaddr_storage addr{};
    socklen_t        addr_len{0};

    Connect(Scheduler& scheduler, int fd, const sockaddr* addr, socklen_t addr_len);

protected:
    void prepare(io_uring_sqe* sqe) noexcept override;
};

struct Open : Awaitable {
    int         dfd;
    const char* path;
    int         flags;
    mode_t      mode;

    Open(Scheduler& scheduler, const char* path, int flags, mode_t mode = 0644, int dfd = AT_FDCWD);

protected:
    void prepare(io_uring_sqe* sqe) noexcept override;
};

struct Poll : Awaitable {
    int      fd;
    uint32_t poll_mask; // POLLIN, POLLOUT, etc. -- same bitmask as poll(2)

    Poll(Scheduler& scheduler, int fd, uint32_t poll_mask);

protected:
    void prepare(io_uring_sqe* sqe) noexcept override;
};

struct Read : Awaitable {
    int                  fd;
    std::span<uint32_t>  buf;
    uint64_t             offset;

    Read(Scheduler& scheduler, int fd_, std::span<uint32_t> buf, uint64_t offset = 0);

protected:
    void prepare(io_uring_sqe* sqe) noexcept override;
};

struct Recv : Awaitable {
    int    fd;
    void*  buf;
    size_t len;
    int    flags;

    Recv(Scheduler& scheduler, int fd_, void* buf, size_t len, int flags = 0);

protected:
    void prepare(io_uring_sqe* sqe) noexcept override;
};

struct Send : Awaitable {
    int         fd;
    const void* buf;
    size_t      len;
    int         flags;

    Send(Scheduler& scheduler, int fd_, const void* buf, size_t len, int flags = 0);

protected:
    void prepare(io_uring_sqe* sqe) noexcept override;
};

struct Stat : Awaitable {
    int          dfd;
    const char*  path;
    struct statx buf{};
    int          flags;
    uint32_t     mask;

    Stat(Scheduler& scheduler, const char* path, int flags = 0, uint32_t mask = STATX_BASIC_STATS, int dfd_ = AT_FDCWD);

protected:
    void prepare(io_uring_sqe* sqe) noexcept override;
};

struct Write : Awaitable {
    int                        fd;
    std::span<const uint32_t>  buf;
    uint64_t                   offset;

    Write(Scheduler& scheduler, int fd_, std::span<const uint32_t> buf, uint64_t offset = 0);

protected:
    void prepare(io_uring_sqe* sqe) noexcept override;
};

} // namespace slim::common::io
